{
  "_comment": "Copy to secrets.config.json and fill in values. This file is gitignored.",
  "_instructions": {
    "step1": "Copy this file to secrets.config.json in the same folder",
    "step2": "Replace all YOUR_* placeholders with actual values",
    "step3": "The secrets.config.json file is gitignored for security"
  },

  "AzureAd": {
    "TenantId": "YOUR_TENANT_ID",
    "ClientId": "YOUR_CLIENT_ID"
  },

  "SonarQube": {
    "Token": "YOUR_SONARQUBE_TOKEN"
  },

  "AzureOpenAI": {
    "ApiKey": "YOUR_AZURE_OPENAI_KEY"
  },

  "Copilot": {
    "ApiKey": "YOUR_GITHUB_COPILOT_API_KEY"
  },

  "AzureDevOps": {
    "PAT": "YOUR_AZURE_DEVOPS_PAT"
  },

  "GitHub": {
    "ClientId": "YOUR_GITHUB_OAUTH_CLIENT_ID",
    "ClientSecret": "YOUR_GITHUB_OAUTH_CLIENT_SECRET",
    "PAT": "YOUR_GITHUB_PAT"
  },

  "MicrosoftGraph": {
    "TenantId": "YOUR_TENANT_ID",
    "ClientId": "YOUR_GRAPH_CLIENT_ID",
    "ClientSecret": "YOUR_GRAPH_CLIENT_SECRET"
  }
}
