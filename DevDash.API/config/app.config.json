{
  "authentication": {
    "entraId": {
      "clientId": "${ENTRA_CLIENT_ID}",
      "tenantId": "${ENTRA_TENANT_ID}",
      "instance": "https://login.microsoftonline.com/",
      "audience": "api://${ENTRA_CLIENT_ID}",
      "scopes": ["499b84ac-1321-427f-aa17-267ca6975798/.default"]
    },
    "github": {
      "clientId": "${GITHUB_CLIENT_ID}",
      "apiUrl": "https://github.yourcompany.com/api/v3",
      "authorizeUrl": "https://github.yourcompany.com/login/oauth/authorize",
      "tokenUrl": "https://github.yourcompany.com/login/oauth/access_token",
      "orgName": "your-org"
    }
  },

  "services": {
    "azureDevOps": {
      "organizationUrl": "https://dev.azure.com/YOUR_ORG",
      "organization": "YOUR_ORG",
      "project": "PowerOperation",
      "repos": ""
    },
    "sonarQube": {
      "url": "https://sonarqube.yourcompany.com",
      "projects": "project-key-1,project-key-2"
    },
    "azureOpenAI": {
      "endpoint": "https://YOUR_RESOURCE.openai.azure.com/",
      "deploymentName": "gpt-4",
      "apiVersion": "2024-02-15-preview"
    },
    "copilot": {
      "enabled": false,
      "endpoint": "/api/copilot/chat",
      "model": "copilot-chat"
    },
    "microsoftGraph": {
      "scopes": "Calendars.ReadWrite OnlineMeetings.ReadWrite"
    },
    "elasticsearch": {
      "uri": "http://localhost:9200",
      "issuesIndex": "devdash-issues",
      "resolutionsIndex": "devdash-resolutions"
    }
  },

  "dashboards": {
    "dev": {
      "name": "Development Dashboard",
      "pipelines": [
        "PowerOperation-CI",
        "PowerOperation-Nightly-Build"
      ],
      "repos": ["PowerOperation/core", "PowerOperation/api"]
    },
    "test": {
      "name": "Test Dashboard",
      "pipelines": [
        "PowerOperation-Integration-Tests",
        "PowerOperation-E2E-Tests",
        "PowerOperation-Performance-Tests"
      ],
      "repos": ["PowerOperation/test-harness"]
    }
  },

  "features": {
    "enableEntraId": true,
    "enableGitHub": true,
    "enableCopilot": false,
    "enableAzureOpenAI": true,
    "enableAIAssistant": true,
    "enablePipelineAlerts": true,
    "enablePRAlerts": true,
    "enableLighthouse": false,
    "usePATToken": true
  },

  "rateLimiting": {
    "aiRequestsPerMinute": 10,
    "devOpsRequestsPerMinute": 30
  },

  "cors": {
    "allowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000"
    ]
  },

  "connectionStrings": {
    "sqlServer": "Server=localhost;Database=DevDash;Trusted_Connection=True;TrustServerCertificate=True;",
    "redis": "localhost:6379"
  },

  "keyVault": {
    "uri": ""
  },

  "logging": {
    "logLevel": {
      "default": "Information",
      "microsoft.AspNetCore": "Warning"
    }
  }
}
