{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "Audience": "api://YOUR_CLIENT_ID"
  },

  "KeyVault": {
    "Uri": ""
  },

  "ConnectionStrings": {
    "SqlServer": "",
    "Redis": ""
  },

  "Elasticsearch": {
    "Uri": "",
    "IssuesIndex": "devdash-issues",
    "ResolutionsIndex": "devdash-resolutions"
  },

  "SonarQube": {
    "Url": "https://sonarqube.yourcompany.com",
    "Projects": "project-key-1,project-key-2"
  },

  "AzureOpenAI": {
    "Endpoint": "https://YOUR_RESOURCE.openai.azure.com/",
    "DeploymentName": "gpt-4",
    "ApiVersion": "2024-02-15-preview"
  },

  "Copilot": {
    "Endpoint": "https://api.github.com/copilot",
    "Model": "copilot-chat"
  },

  "AzureDevOps": {
    "OrganizationUrl": "https://dev.azure.com/YOUR_ORG",
    "Project": "YOUR_PROJECT",
    "Dev": {
      "Repos": "Repo1.API,Repo1.UI,Repo1.Services",
      "Pipelines": "PowerOperation-CI,PowerOperation-Nightly-Build"
    },
    "Test": {
      "Repos": "Repo1.API,Repo1.UI,Repo1.Services",
      "Pipelines": "PowerOperation-Integration-Tests,PowerOperation-E2E-Tests,PowerOperation-Performance-Tests"
    }
  },

  "TestPlans": {
    "Plans": [
      {
        "Name": "Power Operation 2024 Regression",
        "Suites": []
      }
    ],
    "CacheDurationMinutes": 5
  },

  "GitHub": {
    "ApiUrl": "https://api.github.com",
    "AuthorizeUrl": "https://github.com/login/oauth/authorize",
    "TokenUrl": "https://github.com/login/oauth/access_token",
    "Owner": "YOUR_ORG",
    "Dev": {
      "Repos": "repo1,repo2"
    },
    "Test": {
      "Repos": "repo1,repo2"
    }
  },

  "MicrosoftGraph": {
    "Scopes": "Calendars.ReadWrite OnlineMeetings.ReadWrite Mail.Send"
  },

  "PRAlerts": {
    "OverdueHours": 48,
    "OverdueEmail": {
      "To": [
        "team-lead@company.com",
        "manager@company.com"
      ],
      "Cc": [
        "dev-team@company.com"
      ],
      "Subject": "Overdue PR Alert - Action Required"
    },
    "StalePRDays": 7,
    "RequiredApprovers": 2
  },

  "CodeReview": {
    "DefaultReviewers": [
      "john.doe@company.com",
      "jane.smith@company.com",
      "tech.lead@company.com"
    ],
    "MeetingDurationMinutes": 30
  },

  "StoryPoints": {
    "IncludeTypes": ["User Story", "Product Backlog Item"],
    "ExcludeStates": ["Done", "Closed", "Removed"],
    "CurrentIterationOnly": true
  },

  "FeatureFlags": {
    "UseAzureOpenAI": true,
    "UseCopilot": false,
    "EnableAIAssistant": true,
    "EnablePipelineAlerts": true,
    "EnablePRAlerts": true,
    "UsePATToken": true
  },

  "RateLimiting": {
    "EnableForEntraIdOnly": true,
    "AIRequestsPerMinute": 20,
    "DevOpsRequestsPerMinute": 120,
    "PerformanceRequestsPerMinute": 60,
    "SonarQubeRequestsPerMinute": 30,
    "LighthouseRequestsPerMinute": 30
  },

  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000",
      "http://localhost:5000"
    ]
  }
}
