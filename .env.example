# DevDash Frontend Configuration
# Copy this file to .env and update with your values
#
# NOTE: Sensitive tokens (PAT, API keys) go in backend's
# config/secrets.config.json - NOT here.

# ============================================
# Backend API URL
# ============================================
VITE_API_URL=http://localhost:5000/api

# ============================================
# App Environment (dev, test, prod)
# ============================================
VITE_APP_ENV=dev

# ============================================
# Microsoft Entra ID (Client IDs - safe to expose)
# ============================================
VITE_ENTRA_CLIENT_ID=your-entra-client-id
VITE_ENTRA_TENANT_ID=your-tenant-id
VITE_ENTRA_REDIRECT_URI=http://localhost:5173/auth/callback

# ============================================
# GitHub OAuth (Client ID only - safe to expose)
# Client Secret goes in backend secrets.config.json
# ============================================
VITE_GITHUB_OAUTH_ENABLED=true
VITE_GITHUB_CLIENT_ID=your-github-oauth-client-id
VITE_GITHUB_REDIRECT_URI=http://localhost:5173/auth/github/callback

# ============================================
# Feature Flags
# ============================================
VITE_USE_PAT_TOKEN=false
